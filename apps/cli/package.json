{
  "name": "dev-toolkit-cli",
  "version": "1.1.4",
  "repository": "https://github.com/daviinacio/dev-toolkit",
  "author": "Davi Inácio <aazz6850@gmail.com>",
  "license": "MIT",
  "main": "./bin/apps/cli/src/main.js",
  "bin": {
    "dtk": "./bin/apps/cli/src/main.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsc -w",
    "build": "rm -rf bin && tsc",
    "unlink-cli": "yarn --global unlink dev-toolkit-cli",
    "link-cli": "(yarn unlink-cli || true) && chmod +x bin/apps/cli/src/main.js && yarn --global link",
    "prepublish": "yarn build",
    "publish": "npm publish"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "common": "*",
    "mime": "^4.0.6"
  }
}
